# API Configuration
# The mobile app will connect to this backend API URL

# Development: Use your local backend or a shared development server
# VITE_API_URL=http://localhost:3000

# Production: Use your deployed backend URL
# VITE_API_URL=https://api.yourapp.com

# Example with Fly.io deployment
# VITE_API_URL=https://your-app.fly.dev

# Example with Railway deployment
# VITE_API_URL=https://your-app.railway.app

# Default (if not set): Platform auto-detection
# - Android emulator: http://10.0.2.2:3000
# - iOS simulator: http://localhost:3000
# - Web: http://localhost:3000
