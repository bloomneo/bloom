# @file .env.example — template for local + deployment env vars.
#
# bloom's CLI auto-generates a real .env at `bloom create` time with
# random secrets baked in. This file is the checked-in reference so
# humans and agents know which keys exist, their shape, and why they
# matter. Copy to `.env` and fill in the blanks if you scaffolded
# outside the bloom CLI path.

# ─── Database ───────────────────────────────────────────────────────
# PostgreSQL recommended for prod. SQLite works for quick local runs.
DATABASE_URL="postgresql://username:password@localhost:5432/{{PROJECT_NAME}}"
# DATABASE_URL="file:./prisma/dev.db"

# ─── Auth ───────────────────────────────────────────────────────────
# Signing key for JWTs. Rotating this invalidates every session.
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-me-with-a-long-random-string"
JWT_EXPIRES_IN="7d"

# AppKit canonical names — the appkit auth module reads these first.
BLOOM_AUTH_SECRET="replace-me-with-a-long-random-string"

# ─── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated allow-list for the CORS middleware.
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# ─── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Email provider (optional — /admin/settings → Email edits this) ─
# BLOOM_EMAIL_STRATEGY values: resend | smtp | console
# BLOOM_EMAIL_STRATEGY=console
# BLOOM_EMAIL_FROM_NAME="Your Business"
# BLOOM_EMAIL_FROM_EMAIL=noreply@example.com
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Frontend (Vite-exposed — prefixed VITE_ so they ship to the browser)
VITE_API_URL=http://localhost:3000
VITE_APP_NAME="{{PROJECT_NAME}}"
# Optional: brand-name overrides. siteConfig.ts reads these for <title>
# templating and visible brand text. Defaults to VITE_APP_NAME.
# VITE_SITE_NAME="Your Business"
# VITE_SITE_DESCRIPTION="Your one-line pitch"

# Frontend-key gate. appkit's security module rejects /api/* requests
# that don't carry this header. VITE_FRONTEND_KEY + BLOOM_FRONTEND_KEY
# MUST match — the client sends the VITE_ value, the server compares
# against the BLOOM_ value.
VITE_FRONTEND_KEY=bloom_replace_me
BLOOM_FRONTEND_KEY=bloom_replace_me

# ─── Seeding ────────────────────────────────────────────────────────
# Default password for every account created by prisma/seeding/user.seed.js.
# Only used at seed time. Never committed.
DEFAULT_USER_PASSWORD="change-me-before-real-use"

# ─── Security ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true

# ─── Session ────────────────────────────────────────────────────────
SESSION_SECRET="replace-me-with-a-long-random-string"
SESSION_MAX_AGE=86400000

# ─── adminapp feature flags ─────────────────────────────────────────
# Allowed role:level pairs. Parsed by admin.roles.ts on boot.
# Template ships three tiers: admin / moderator / user. Add more if
# needed (remember to update user.route.ts gates and the seed too).
ADMIN_USER_ROLES="admin:system,moderator:manage,user:basic"

# Master switch for the audit log. false = auditService.logAudit is a
# no-op. Never set false in prod.
ADMIN_ENABLE_AUDIT_LOG=true

# Dashboard widgets rendered by default on /admin. Users can override
# per-browser via /admin/settings → Appearance.
ADMIN_DASHBOARD_WIDGETS="users,signups,activity"
