{
  "name": "@bloomneo/bloom",
  "version": "4.2.3",
  "description": "Scaffolding CLI that combines @bloomneo/uikit (React) and @bloomneo/appkit (Express) with Feature-Based Component Architecture (FBCA) into full-stack web/desktop/mobile apps.",
  "type": "module",
  "main": "./bin/bloom.js",
  "bin": {
    "bloom": "./bin/bloom.js"
  },
  "files": [
    "bin",
    "templates",
    "AGENTS.md",
    "llms.txt",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run check:docs && npm run test:smoke",
    "test:smoke": "node --test tests/scaffold-smoke.test.mjs",
    "check:docs": "node scripts/check-doc-drift.mjs",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bloomneo/bloom.git"
  },
  "homepage": "https://github.com/bloomneo/bloom#readme",
  "bugs": {
    "url": "https://github.com/bloomneo/bloom/issues"
  },
  "keywords": [
    "fullstack",
    "framework",
    "fbca",
    "feature-based",
    "component-architecture",
    "uikit",
    "appkit",
    "react",
    "express",
    "cli",
    "scaffolding",
    "typescript",
    "vite",
    "auto-discovery",
    "routing",
    "zero-config",
    "mobile",
    "ios",
    "android",
    "capacitor",
    "electron",
    "desktop"
  ],
  "author": {
    "name": "Bloomneo",
    "url": "https://bloomneo.com"
  },
  "contributors": [
    {
      "name": "Krishna Teja GS",
      "email": "kt@voilacode.com",
      "url": "https://bloomneo.com"
    }
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/bloomneo"
  },
